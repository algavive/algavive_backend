{
  "name": "algavive_backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy",

    "migrate:create": "wrangler d1 migrations create algavive-db",
    "migrate:local": "wrangler d1 migrations apply algavive-db --local",
    "migrate:remote": "wrangler d1 migrations apply algavive-db --remote",
    "migrate:status": "wrangler d1 migrations list algavive-db --local",

    "db:reset": "rmdir /s /q .wrangler",
    "db:test": "wrangler d1 execute algavive-db --file=src/tests.sql --local"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.100.0"
  }
}
